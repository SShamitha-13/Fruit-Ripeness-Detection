   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import os\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.metrics import accuracy_score, classification_report\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Path to dataset\n",
    "dataset_path = r\"C:\\Users\\sreer\\Downloads\\fruit_ripeness_detection\\dataset\"\n",
    "\n",
    "# Categories\n",
    "classes = ['unripe', 'ripe', 'overripe']\n",
    "\n",
    "# Data containers\n",
    "X, y, images = [], [], []\n",
    "\n",
    "# Read and extract features\n",
    "for label, fruit_class in enumerate(classes):\n",
    "    class_folder = os.path.join(dataset_path, fruit_class)\n",
    "    for filename in os.listdir(class_folder):\n",
    "        img_path = os.path.join(class_folder, filename)\n",
    "        img = cv2.imread(img_path)\n",
    "        if img is None:\n",
    "            print(f\" Skipping unreadable file: {img_path}\")\n",
    "            continue\n",
    "\n",
    "        img_resized = cv2.resize(img, (256, 256))\n",
    "\n",
    "        images.append(img_resized)\n",
    "\n",
    "        # Extract color and texture features\n",
    "        mean_color = np.mean(img_resized, axis=(0, 1))\n",
    "        std_color = np.std(img_resized, axis=(0, 1))\n",
    "        features = np.concatenate([mean_color, std_color])\n",
    "        X.append(features)\n",
    "        y.append(label)\n",
    "\n",
    "X = np.array(X)\n",
    "y = np.array(y)\n",
    "\n",
    "print(\" Features extracted from all images!\")\n",
    "\n",
    "X_train, X_test, y_train, y_test, images_train, images_test = train_test_split(\n",
    "    X, y, images, test_size=0.3, random_state=42\n",
    ")\n",
    "\n",
    "\n",
    "model = SVC(kernel='linear')\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "y_pred = model.predict(X_test)\n",
    "\n",
    "print(\"\\n Model trained successfully!\")\n",
    "print(\"Accuracy:\", accuracy_score(y_test, y_pred))\n",
    "print(\"\\nClassification Report:\\n\", classification_report(y_test, y_pred, target_names=classes))\n",
    "\n",
    "\n",
    "for i in range(len(X_test)):\n",
    "    plt.imshow(cv2.cvtColor(images_test[i], cv2.COLOR_BGR2RGB))\n",
    "    plt.title(f\"Actual: {classes[y_test[i]]} | Predicted: {classes[y_pred[i]]}\")\n",
    "    plt.axis('off')\n",
    "    plt.show()\n"
   ]
